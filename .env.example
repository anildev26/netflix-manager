# Copy this file to .env for local development
# On Railway/Render, set these as environment variables in the dashboard

# Admin login credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-strong-password-here

# Random secret for signing JWT tokens (use any long random string)
JWT_SECRET=replace-this-with-a-long-random-secret-at-least-32-characters

# Server port (Railway/Render set this automatically)
PORT=3000
